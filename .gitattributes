# Auto detect text files and perform LF normalization.
* text=auto

# Unity YAML assets.
*.unity text eol=lf linguist-language=YAML
*.prefab text eol=lf linguist-language=YAML
*.asset text eol=lf linguist-language=YAML
*.meta text eol=lf linguist-language=YAML
*.mat text eol=lf linguist-language=YAML
*.anim text eol=lf linguist-language=YAML
*.controller text eol=lf linguist-language=YAML
*.overrideController text eol=lf linguist-language=YAML
*.physicsMaterial2D text eol=lf linguist-language=YAML
*.physicsMaterial text eol=lf linguist-language=YAML

# Code and project text files.
*.cs text diff=csharp
*.shader text
*.hlsl text
*.cginc text
*.json text eol=lf
*.md text eol=lf

# Common binary assets.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.psd binary
*.tga binary
*.tif binary
*.tiff binary
*.fbx binary
*.obj binary
*.blend binary
*.wav binary
*.mp3 binary
*.ogg binary
*.mp4 binary
*.mov binary
